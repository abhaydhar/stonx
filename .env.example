# StockScanner environment template
# Copy this file to .env for local runs.

# Required only for full LLM agent runs, such as: python run_scanner.py
# Core module tests and python run_scanner.py --dry-run do not require this.
ANTHROPIC_API_KEY=

# Optional alerting settings. Leave blank unless alerts are enabled.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional database and local data paths.
DATABASE_URL=sqlite:///./data/stonx.db
DATA_CACHE_DIR=./data/cache
FUNDAMENTALS_DIR=./data/fundamentals

# Optional: fetch a live NSE index constituent list instead of the static
# data/universe/nse_universe.csv. Values: nifty50, niftynext50, nifty100,
# nifty200, nifty500, niftymidcap150, niftysmallcap250, all. Leave blank to
# use the static CSV (no network required).
NSE_UNIVERSE_INDEX=
NSE_UNIVERSE_CACHE_TTL_HOURS=24.0

# Optional logging and scheduler settings.
LOG_LEVEL=INFO
LOG_DIR=./logs
MARKET_CLOSE_TIME=15:30
SCANNER_RUN_TIME=16:00

# Optional scanner/risk thresholds. Defaults match config.py.
CAPITAL=1000000
RISK_PCT=0.01
MIN_RR=2.5
PORTFOLIO_HEAT_LIMIT=0.05
MAX_CONCURRENT_POSITIONS=10
MIN_MARKET_CAP_CR=500
MIN_REVENUE_GROWTH=0.0
MAX_DEBT_TO_EQUITY=1.0
MIN_PROMOTER_HOLDING=0.40
VOLUME_LOOKBACK_DAYS=100
CONSOLIDATION_DAYS=20
CONSOLIDATION_RANGE_PCT=0.08
VOLUME_SPIKE_MULTIPLIER=1.5
UPTREND_MIN_GAIN_PCT=0.20
UPTREND_LOOKBACK_DAYS=60
HVN_THRESHOLD=1.5
LVN_THRESHOLD=0.5
VOLUME_PROFILE_BINS=20
NIFTY_SMA_PERIOD=200
BULL_MARKET_MIN_RR=2.5
BEAR_MARKET_MIN_RR=3.5
SECTOR_CORRELATION_LIMIT=2

# Optional model names for future/agent workflows.
SCANNER_AGENT_MODEL=claude-haiku-4-5
RESEARCH_AGENT_MODEL=claude-sonnet-4-5
RISK_AGENT_MODEL=claude-sonnet-4-5
EXECUTION_AGENT_MODEL=claude-haiku-4-5
LEARNING_AGENT_MODEL=claude-opus-4-8
